<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="PokedexRed">#DC3545</Color>
    <Color x:Key="PokedexRedDark">#B02A37</Color>
    <Color x:Key="AppBackground">#F4F6F8</Color>
    <SolidColorBrush x:Key="PokedexRedBrush" Color="{StaticResource PokedexRed}"/>
    <SolidColorBrush x:Key="PokedexRedDarkBrush" Color="{StaticResource PokedexRedDark}"/>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}"/>
</ResourceDictionary>
