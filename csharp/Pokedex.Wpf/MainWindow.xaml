<Window x:Class="Pokedex.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:Pokedex.Wpf.Controls"
        Title="Pokédex"
        Width="1280" Height="800"
        MinWidth="1000" MinHeight="640"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:HeightConverter x:Key="HeightFmt" xmlns:conv="clr-namespace:Pokedex.Wpf.Converters"/>
        <conv:WeightConverter x:Key="WeightFmt" xmlns:conv="clr-namespace:Pokedex.Wpf.Converters"/>
        <conv:PageLabelConverter x:Key="PageLabel" xmlns:conv="clr-namespace:Pokedex.Wpf.Converters"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Pokédex" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBox Width="280" Padding="10,8" FontSize="14"
                                 AutomationProperties.Name="Recherche Pokémon"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Content="Chercher" Style="{StaticResource AccentButton}" Margin="8,0,0,0"
                                Command="{Binding SearchCommand}"/>
                        <Button Content="★" Style="{StaticResource AccentButton}" Margin="6,0,0,0" Width="36"
                                Command="{Binding ToggleFavoriteCommand}" ToolTip="Favori"/>
                        <Button Content="⇄" Style="{StaticResource AccentButton}" Margin="6,0,0,0" Width="36"
                                Command="{Binding ToggleCompareModeCommand}" ToolTip="Comparer"/>
                        <Button Content="♫" Style="{StaticResource AccentButton}" Margin="6,0,0,0" Width="36"
                                Command="{Binding PlayCryCommand}" ToolTip="Cri"/>
                    </StackPanel>
                    <CheckBox Grid.Column="2" Content="Chromatique" VerticalAlignment="Center"
                              IsChecked="{Binding IsShiny}" FontWeight="SemiBold"/>
                </Grid>
                <Border Background="#FFF3CD" Padding="6" Margin="0,8,0,0" CornerRadius="6"
                        Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisible}}">
                    <TextBlock Text="Mode hors ligne : impossible de joindre PokéAPI." Foreground="#856404" HorizontalAlignment="Center"/>
                </Border>
                <ItemsControl ItemsSource="{Binding SearchHistoryItems}" Margin="0,8,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Margin="2" Padding="6,2" FontSize="11"
                                    Command="{Binding DataContext.UseHistoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource PokedexRedBrush}" CornerRadius="10,10,0,0" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Pokédex National" Foreground="White" FontSize="15" FontWeight="Bold"/>
                            <TextBox Margin="0,10,0,0" Padding="8,6"
                                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding FilteredList}"
                             SelectedItem="{Binding SelectedListItem}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2,5">
                                    <TextBlock Text="{Binding Id, StringFormat={}{0:D3}}" Width="40" Foreground="Gray" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <DockPanel Grid.Row="2" Margin="10">
                        <Button DockPanel.Dock="Left" Content="◀" Width="40" Style="{StaticResource AccentButton}"
                                Command="{Binding PreviousPageCommand}"/>
                        <Button DockPanel.Dock="Right" Content="▶" Width="40" Style="{StaticResource AccentButton}"
                                Command="{Binding NextPageCommand}"/>
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource PageLabel}">
                                    <Binding Path="CurrentPage"/>
                                    <Binding Path="TotalPages"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </DockPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="10">
                <Grid>
                    <TextBlock Text="Sélectionnez un Pokémon ou recherchez par nom."
                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray" FontSize="15"
                               Visibility="{Binding SelectedPokemon, Converter={StaticResource NullToVisible}, ConverterParameter=invert}"/>

                    <Grid Visibility="{Binding SelectedPokemon, Converter={StaticResource NullToVisible}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="20,16" Orientation="Horizontal">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedPokemon.Id, StringFormat=N° {0:D3}}" Foreground="Gray"/>
                                <TextBlock Text="{Binding SelectedPokemon.DisplayName}" FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource PokedexRedBrush}"/>
                                <TextBlock Text="{Binding SelectedPokemon.Genus}" FontStyle="Italic" Foreground="Gray"/>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="Gray" Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <TabControl Grid.Row="1" Margin="8" BorderThickness="0">
                            <TabItem Header="Détails">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <Grid Margin="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#FAFAFA" CornerRadius="12" Padding="12" Margin="0,0,8,0" MinHeight="280">
                                            <Image Source="{Binding SpriteImage}" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <ItemsControl ItemsSource="{Binding SelectedPokemon.Types}" Margin="0,0,0,12">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,6,0" Padding="10,4" CornerRadius="10"
                                                                Background="{Binding Converter={StaticResource TypeToBrush}}">
                                                            <TextBlock Text="{Binding}" Foreground="White" FontWeight="Bold"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Margin="0,0,0,4">
                                                <Run Text="Taille : " FontWeight="Bold"/>
                                                <Run Text="{Binding SelectedPokemon.Height, Converter={StaticResource HeightFmt}}"/>
                                            </TextBlock>
                                            <TextBlock Margin="0,0,0,4">
                                                <Run Text="Poids : " FontWeight="Bold"/>
                                                <Run Text="{Binding SelectedPokemon.Weight, Converter={StaticResource WeightFmt}}"/>
                                            </TextBlock>
                                            <TextBlock Margin="0,0,0,4">
                                                <Run Text="Habitat : " FontWeight="Bold"/>
                                                <Run Text="{Binding SelectedPokemon.Habitat}"/>
                                                <Run Text="  ·  Génération : "/>
                                                <Run Text="{Binding SelectedPokemon.Generation}"/>
                                            </TextBlock>
                                            <TextBlock Margin="0,0,0,12">
                                                <Run Text="Capture : " FontWeight="Bold"/>
                                                <Run Text="{Binding SelectedPokemon.CaptureRate}"/>
                                                <Run Text="  ·  XP : "/>
                                                <Run Text="{Binding SelectedPokemon.BaseExperience}"/>
                                            </TextBlock>
                                            <TextBlock Text="Talents" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <ItemsControl ItemsSource="{Binding SelectedPokemon.Abilities}" Margin="0,0,0,12">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Margin="0,2" Text="{Binding DisplayName, StringFormat=• {0}}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="Description" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding SelectedPokemon.Description}" TextWrapping="Wrap"
                                                       Background="#F8F9FA" Padding="10" LineHeight="20"/>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Stats">
                                <ScrollViewer>
                                    <StackPanel Margin="20">
                                        <TextBlock Text="{Binding BaseStatTotal, StringFormat=Total BST : {0}}"
                                                   FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource PokedexRedDarkBrush}"/>
                                        <ItemsControl ItemsSource="{Binding SelectedPokemon.Stats}" Margin="0,16,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="90"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="36"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                        <ProgressBar Grid.Column="1" Height="12" Margin="8,0" Maximum="255"
                                                                     Value="{Binding Value}"
                                                                     Foreground="{Binding Value, Converter={StaticResource StatToBrush}}"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Value}" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Combat">
                                <ScrollViewer Margin="16">
                                    <StackPanel>
                                        <TextBlock Text="Faiblesses" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <ItemsControl ItemsSource="{Binding SelectedPokemon.Weaknesses}" Margin="0,0,0,16">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="8"
                                                            Background="{Binding Converter={StaticResource TypeToBrush}}">
                                                        <TextBlock Text="{Binding}" Foreground="White" FontWeight="Bold"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="Résistances" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <ItemsControl ItemsSource="{Binding SelectedPokemon.Resistances}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="8"
                                                            Background="{Binding Converter={StaticResource TypeToBrush}}">
                                                        <TextBlock Text="{Binding}" Foreground="White" FontWeight="Bold"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Formes">
                                <ScrollViewer>
                                    <ItemsControl ItemsSource="{Binding Forms}" Margin="16">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="8" Padding="10" BorderBrush="#EEE" BorderThickness="1" CornerRadius="8" Width="160">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center"/>
                                                        <Image Height="120" Stretch="Uniform" Margin="0,8">
                                                            <Image.Source>
                                                                <BitmapImage UriSource="{Binding ImageUrl}" CacheOption="OnLoad"/>
                                                            </Image.Source>
                                                        </Image>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Évolutions">
                                <ctrl:EvolutionTreeView
                                    Tree="{Binding SelectedPokemon.EvolutionTree}"
                                    CurrentPokemonId="{Binding SelectedPokemon.Id}"
                                    Shiny="{Binding IsShiny}"/>
                            </TabItem>
                        </TabControl>

                        <Border Grid.Row="1" Background="#F8F9FA" Padding="12" Margin="8"
                                VerticalAlignment="Bottom"
                                Visibility="{Binding ComparePokemon, Converter={StaticResource NullToVisible}}">
                            <StackPanel>
                                <TextBlock Text="Comparaison BST" FontWeight="Bold"/>
                                <TextBlock>
                                    <Run Text="{Binding SelectedPokemon.DisplayName}"/>
                                    <Run Text=" : "/>
                                    <Run Text="{Binding BaseStatTotal}" FontWeight="Bold"/>
                                    <Run Text="  vs  "/>
                                    <Run Text="{Binding ComparePokemon.DisplayName}"/>
                                    <Run Text=" : "/>
                                    <Run Text="{Binding CompareStatTotal}" FontWeight="Bold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Background="#CCFFFFFF"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="180" Height="5"/>
                            <TextBlock Text="Chargement..." Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFEBEE" Padding="10" Margin="12" CornerRadius="6"
                            VerticalAlignment="Top"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisible}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#B71C1C" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
